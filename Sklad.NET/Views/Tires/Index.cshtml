@model IndexViewModel

@{
    ViewData["Title"] = L["Inventory"].Value;
    var here = $"{Context.Request.Path}{Context.Request.QueryString}";
    var f = Model.Filter;
    int activeFilters = (string.IsNullOrWhiteSpace(f.Sku) ? 0 : 1)
                      + (string.IsNullOrWhiteSpace(f.Barcode) ? 0 : 1)
                      + (string.IsNullOrWhiteSpace(f.Brand) ? 0 : 1)
                      + (string.IsNullOrWhiteSpace(f.Model) ? 0 : 1)
                      + (f.Width.HasValue ? 1 : 0)
                      + (f.Profile.HasValue ? 1 : 0)
                      + (f.Diameter.HasValue ? 1 : 0)
                      + (f.Season.HasValue ? 1 : 0)
                      + (f.Type.HasValue ? 1 : 0)
                      + (string.IsNullOrWhiteSpace(f.Location) ? 0 : 1)
                      + (f.LowOnly == true ? 1 : 0);

    Dictionary<string, string?> Route(string? sort, int page) => new()
    {
        ["Sku"] = f.Sku, ["Barcode"] = f.Barcode, ["Brand"] = f.Brand, ["Model"] = f.Model,
        ["Width"] = f.Width?.ToString(), ["Profile"] = f.Profile?.ToString(), ["Diameter"] = f.Diameter?.ToString(),
        ["Season"] = f.Season?.ToString(), ["Type"] = f.Type?.ToString(),
        ["Location"] = f.Location, ["LowOnly"] = f.LowOnly == true ? "true" : null,
        ["Sort"] = sort, ["Page"] = page == 1 ? null : page.ToString()
    };

    // null means the default brand sort — the marker must show it, or clicking
    // "Tire" once appears to do nothing.
    string EffectiveSort = f.Sort ?? "brand";
    string SortToggle(string key) => EffectiveSort == key ? "-" + key : key;
    string SortMark(string key) => EffectiveSort == key ? " ▲" : (f.Sort == "-" + key ? " ▼" : "");
    string? AriaSort(string key) => EffectiveSort == key ? "ascending" : (f.Sort == "-" + key ? "descending" : null);

    async Task SortHeader(string key, string label, bool numeric = false)
    {
        <th scope="col" aria-sort="@AriaSort(key)" class="@(numeric ? "col-num" : null)"><a asp-action="Index" asp-all-route-data="@Route(SortToggle(key), 1)">@L[label]<span class="sort-mark" aria-hidden="true">@SortMark(key)</span></a></th>
    }
}

<div class="page">
    <div class="container">

        <div class="page-head">
            <div>
                <div class="eyebrow">@L["Warehouse"]</div>
                <h1 class="page-title">@L["Inventory"]</h1>
                <p class="page-lede">@L["{0} SKUs across all brands.", Model.Stats.TotalSkus]</p>
            </div>
            <div class="head-actions">
                <form method="get" asp-action="Scan" class="scan-form">
                    <label class="visually-hidden" for="scan-code">@L["Scan SKU or barcode"]</label>
                    <input id="scan-code" name="code" class="field-input" placeholder="@L["Scan SKU or barcode"]"
                           autocomplete="off" autofocus />
                    <button type="submit" class="btn btn-secondary btn-sm">@L["Scan"]</button>
                </form>
                <a asp-action="Export" asp-all-route-data="@Route(f.Sort, 1)"
                   class="btn btn-secondary btn-sm">@L["Export CSV"]</a>
                <a asp-action="ExportExcel" asp-all-route-data="@Route(f.Sort, 1)"
                   class="btn btn-secondary btn-sm">@L["Export Excel"]</a>
                <a asp-action="Create" class="btn btn-primary btn-sm">@L["Add Tire"]</a>
            </div>
        </div>

        @if (TempData["ScanMessage"] is string scanMessage)
        {
            <div class="notice" role="status">@scanMessage</div>
        }

        <div class="statband">
            <div class="stat">
                <div class="stat-num num">@Model.Stats.TotalSkus</div>
                <div class="stat-label">@L["Total SKUs"]</div>
            </div>
            <div class="stat">
                <div class="stat-num num">@Model.Stats.TotalUnits</div>
                <div class="stat-label">@L["Units in Stock"]</div>
            </div>
            <a class="stat @(Model.Stats.LowStockCount > 0 ? "is-alert" : "")" asp-action="LowStock">
                <div class="stat-num num">@Model.Stats.LowStockCount</div>
                <div class="stat-label">@L["Low Stock"]</div>
            </a>
            <a class="stat" asp-action="Report">
                <div class="stat-num num">@Money.Euro(Model.Stats.TotalValue, 0)</div>
                <div class="stat-label">@L["Inventory Value"]</div>
                <div class="stat-sub">@Money.Lev(Model.Stats.TotalValue, 0)</div>
            </a>
        </div>

        <details class="filter" @(f.HasAnyFilter ? "open" : "")>
            <summary>
                @L["Filter"]
                @if (activeFilters > 0)
                {
                    <span class="filter-count">@L["{0} active", activeFilters]</span>
                }
            </summary>
            <form method="get" asp-action="Index" class="filter-body">
                <div class="filter-fields">
                    <div class="field">
                        <label class="field-label" for="filter-sku">@L["SKU"]</label>
                        <input id="filter-sku" name="Sku" value="@f.Sku" class="field-input" placeholder="MCH-001" />
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-barcode">@L["Barcode"]</label>
                        <input id="filter-barcode" name="Barcode" value="@f.Barcode" class="field-input" placeholder="3528706782900" />
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-brand">@L["Brand"]</label>
                        <select id="filter-brand" name="Brand" class="field-select">
                            <option value="">@L["Any brand"]</option>
                            @foreach (var b in Model.Options.Brands)
                            {
                                <option value="@b" selected="@(f.Brand == b)">@b</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-model">@L["Model"]</label>
                        <input id="filter-model" name="Model" value="@f.Model" class="field-input" placeholder="Pilot Sport" />
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-width">@L["Width"]</label>
                        <select id="filter-width" name="Width" class="field-select">
                            <option value="">@L["Any width"]</option>
                            @foreach (var w in Model.Options.Widths)
                            {
                                <option value="@w" selected="@(f.Width == w)">@w</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-profile">@L["Profile"]</label>
                        <select id="filter-profile" name="Profile" class="field-select">
                            <option value="">@L["Any profile"]</option>
                            @foreach (var p in Model.Options.Profiles)
                            {
                                <option value="@p" selected="@(f.Profile == p)">@p</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-diameter">@L["Diameter"]</label>
                        <select id="filter-diameter" name="Diameter" class="field-select">
                            <option value="">@L["Any diameter"]</option>
                            @foreach (var d in Model.Options.Diameters)
                            {
                                <option value="@d" selected="@(f.Diameter == d)">@d</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-season">@L["Season"]</label>
                        <select id="filter-season" name="Season" class="field-select">
                            <option value="">@L["Any season"]</option>
                            @foreach (Season s in Enum.GetValues<Season>())
                            {
                                <option value="@s" selected="@(f.Season == s)">@L[Enums.Key(s)]</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-type">@L["Type"]</label>
                        <select id="filter-type" name="Type" class="field-select">
                            <option value="">@L["Any type"]</option>
                            @foreach (TireType t in Enum.GetValues<TireType>())
                            {
                                <option value="@t" selected="@(f.Type == t)">@L[Enums.Key(t)]</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-location">@L["Location"]</label>
                        <select id="filter-location" name="Location" class="field-select">
                            <option value="">@L["Any location"]</option>
                            @foreach (var loc in Model.Options.Locations)
                            {
                                <option value="@loc" selected="@(f.Location == loc)">@loc</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label" for="filter-low">@L["Stock level"]</label>
                        <select id="filter-low" name="LowOnly" class="field-select">
                            <option value="">@L["Any stock level"]</option>
                            <option value="true" selected="@(f.LowOnly == true)">@L["Low stock only"]</option>
                        </select>
                    </div>
                    <div class="field field-buttons">
                        <button type="submit" class="btn btn-primary">@L["Search"]</button>
                        <a asp-action="Index" class="btn btn-secondary">@L["Clear"]</a>
                    </div>
                </div>
            </form>
        </details>

        <div class="block">
            <div class="block-head">
                <h2 class="block-title">@(f.HasAnyFilter ? L["Filtered Results"] : L["All Tires"])</h2>
                <span class="block-meta">
                    @if (f.HasAnyFilter)
                    {
                        <span>@L["{0} of {1} SKUs", Model.Results.TotalCount, Model.Stats.TotalSkus]</span>
                        <span> &mdash; </span>
                        <a asp-action="Index">@L["Clear filter"]</a>
                    }
                    else
                    {
                        <span>@L["{0} SKUs", Model.Results.TotalCount]</span>
                    }
                </span>
            </div>

            <div class="table-scroll" tabindex="0" role="region" aria-label="@L["Inventory"]">
                @if (!Model.Results.Items.Any())
                {
                    @if (f.HasAnyFilter)
                    {
                        <div class="empty">
                            <strong>@L["No matching tires"]</strong>
                            @L["Adjust the filter or clear it to see the full inventory."]
                        </div>
                    }
                    else
                    {
                        <div class="empty">
                            <strong>@L["The warehouse is empty"]</strong>
                            @L["Add your first tire to start tracking stock."]
                            <div class="empty-action">
                                <a asp-action="Create" class="btn btn-primary">@L["Add Tire"]</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <table class="data-table data-table-wide">
                        <colgroup>
                            <col class="w-sku" /><col class="w-tire" /><col class="w-size" />
                            <col class="w-class" /><col class="w-price" /><col class="w-qty" />
                            <col class="w-loc" /><col class="w-act" />
                        </colgroup>
                        <thead>
                            <tr>
                                @{
                                    await SortHeader("sku", "SKU");
                                    await SortHeader("brand", "Tire");
                                    await SortHeader("size", "Size");
                                }
                                <th scope="col">@L["Season / Type"]</th>
                                @{
                                    await SortHeader("price", "Price", numeric: true);
                                    await SortHeader("qty", "Qty / Min", numeric: true);
                                }
                                <th scope="col">@L["Location"]</th>
                                <th scope="col"><span class="visually-hidden">@L["Actions"]</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Results.Items)
                            {
                                <tr class="@(t.IsLowStock ? "is-low" : "")" data-href="@Url.Action("Details", new { id = t.Id, returnUrl = here })">
                                    <td class="mono"><a class="row-link" asp-action="Details" asp-route-id="@t.Id" asp-route-returnUrl="@here">@t.Sku</a></td>
                                    <td>
                                        <a class="row-link" asp-action="Details" asp-route-id="@t.Id" asp-route-returnUrl="@here">
                                            <span class="cell-stack cell-strong">@t.Brand</span>
                                            <span class="cell-sub">@t.Model</span>
                                        </a>
                                    </td>
                                    <td class="mono">@t.Size</td>
                                    <td>
                                        <span class="cell-stack tag">@L[Enums.Key(t.Season)]</span>
                                        <span class="cell-sub">@L[Enums.Key(t.Type)]</span>
                                    </td>
                                    <td class="col-num"><money value="t.UnitPrice" /></td>
                                    <td class="col-num">
                                        <span class="cell-stack @(t.IsLowStock ? "qty-low" : "")">@t.Quantity</span>
                                        <span class="cell-sub">@L["/ min {0}", t.MinStock]</span>
                                    </td>
                                    <td class="cell-muted">@(t.Location ?? "—")</td>
                                    <td>
                                        <div class="row-actions">
                                            <a asp-action="RegisterMovement" asp-route-id="@t.Id" asp-route-returnUrl="@here">@L["Move"]</a>
                                            <a asp-action="Edit" asp-route-id="@t.Id" asp-route-returnUrl="@here">@L["Edit"]</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            @if (Model.Results.TotalPages > 1)
            {
                <div class="pager">
                    @if (Model.Results.HasPrevious)
                    {
                        <a class="btn btn-secondary btn-sm" asp-action="Index"
                           asp-all-route-data="@Route(f.Sort, Model.Results.Page - 1)">@L["Previous"]</a>
                    }
                    <span class="pager-info">@L["Page {0} of {1}", Model.Results.Page, Model.Results.TotalPages]</span>
                    @if (Model.Results.HasNext)
                    {
                        <a class="btn btn-secondary btn-sm" asp-action="Index"
                           asp-all-route-data="@Route(f.Sort, Model.Results.Page + 1)">@L["Next"]</a>
                    }
                </div>
            }
        </div>

    </div>
</div>
