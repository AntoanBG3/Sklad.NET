@model Sklad.Models.Tire

@{
    ViewData["Title"] = L["Delete Tire"].Value;
    var blocked = (bool)(ViewBag.HasMovements ?? false);
}

<div class="page">
    <div class="container container-narrow">

        <div class="page-head">
            <div>
                <div class="eyebrow is-alert">@L["Confirm"]</div>
                <h1 class="page-title">@L["Delete Tire"]</h1>
                <p class="page-lede">@L["This action cannot be undone."]</p>
            </div>
            <div class="head-actions">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary btn-sm">@L["Back"]</a>
            </div>
        </div>

        <div class="confirm">
            <div asp-validation-summary="ModelOnly" class="form-errors"></div>
            @if (blocked)
            {
                <div class="confirm-warning">
                    <div class="eyebrow">@L["Deletion blocked"]</div>
                    <p>@L["This tire has movement records and cannot be deleted."] @L["To clear stock instead, record an Adjustment movement to zero."]</p>
                </div>
            }
            else
            {
                <div class="confirm-warning">
                    <div class="eyebrow">@L["Permanent deletion"]</div>
                    <p>@L["You are about to permanently remove this tire from the inventory. Tires with existing movement records cannot be deleted — clear those first."]</p>
                </div>
            }

            <dl class="specs">
                <dt>@L["SKU"]</dt>
                <dd class="mono">@Model.Sku</dd>
                <dt>@L["Brand"]</dt>
                <dd>@Model.Brand</dd>
                <dt>@L["Model"]</dt>
                <dd>@Model.Model</dd>
                <dt>@L["Size"]</dt>
                <dd class="mono">@Model.Size</dd>
                <dt>@L["Quantity"]</dt>
                <dd>@L["{0} units", Model.Quantity]</dd>
            </dl>

            @if (blocked)
            {
                <div class="form-actions">
                    <a asp-action="RegisterMovement" asp-route-id="@Model.Id" class="btn btn-primary">@L["Add Movement"]</a>
                    <a asp-action="Index" class="btn btn-secondary">@L["Cancel"]</a>
                </div>
            }
            else
            {
                <form asp-action="Delete" class="form-actions">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">@L["Delete Tire"]</button>
                    <a asp-action="Index" class="btn btn-secondary">@L["Cancel"]</a>
                </form>
            }
        </div>

    </div>
</div>
