@model Sklad.ViewModels.RegisterMovementViewModel

@{
    var tire = (Sklad.Models.Tire)ViewBag.Tire;
    ViewData["Title"] = $"{L["Add Movement"].Value} — {tire.Brand} {tire.Model}";
}

<div class="page">
    <div class="container">

        <div class="page-head">
            <div>
                <div class="eyebrow">@L["Stock Ledger"]</div>
                <h1 class="page-title">@L["Add Movement"]</h1>
                <p class="page-lede mono">@tire.Brand @tire.Model &bull; @tire.Size &bull; @tire.Sku</p>
            </div>
        </div>

        <div class="grid">
            <div class="col-5">
                <div class="block">
                    <div class="block-head">
                        <h2 class="block-title">@L["Current Stock"]</h2>
                    </div>
                    <dl class="specs">
                        <dt>@L["Brand"]</dt>
                        <dd class="dd-strong">@tire.Brand</dd>
                        <dt>@L["Model"]</dt>
                        <dd>@tire.Model</dd>
                        <dt>@L["Size"]</dt>
                        <dd class="mono">@tire.Size</dd>
                        <dt>@L["Quantity"]</dt>
                        <dd>
                            <span class="@(tire.IsLowStock ? "qty-low" : "dd-strong")">@tire.Quantity</span>
                            <span class="cell-muted"> @L["/ min {0}", tire.MinStock]</span>
                        </dd>
                        <dt>@L["Location"]</dt>
                        <dd>@(tire.Location ?? "—")</dd>
                    </dl>
                </div>
            </div>

            <div class="col-7">
                <form asp-action="RegisterMovement" method="post" asp-route-returnUrl="@ViewBag.ReturnUrl" class="block" data-guard>
                    <div class="block-head">
                        <h2 class="block-title">@L["Movement Details"]</h2>
                    </div>

                    <input type="hidden" asp-for="TireId" />

                    <div asp-validation-summary="ModelOnly" class="form-errors"></div>

                    <fieldset class="field">
                        <legend class="field-label">@L["Movement Type"]</legend>
                        <div class="segmented">
                            @foreach (MovementType mt in Enum.GetValues<MovementType>())
                            {
                                <label class="segment">
                                    <input type="radio" asp-for="MovementType" value="@mt" id="mt-@mt" />
                                    <span>@L[Enums.Key(mt)]</span>
                                </label>
                            }
                        </div>
                        <span asp-validation-for="MovementType" class="field-error"></span>
                        <p class="field-hint" id="mt-hint">
                            <span data-mt="In"><strong>@L[Enums.Key(MovementType.In)]</strong> @L["adds units"]</span>
                            <span data-mt="Out"><strong>@L[Enums.Key(MovementType.Out)]</strong> @L["subtracts units"]</span>
                            <span data-mt="Adjustment"><strong>@L[Enums.Key(MovementType.Adjustment)]</strong> @L["sets the exact quantity"]</span>
                        </p>
                    </fieldset>

                    <div class="field">
                        <label asp-for="Quantity" class="field-label">@L["Quantity"]</label>
                        <div class="input-group">
                            <input asp-for="Quantity" type="number" min="0" class="field-input" placeholder="0" />
                            <button type="button" class="btn btn-secondary btn-sm qty-step" data-step="1">+1</button>
                            <button type="button" class="btn btn-secondary btn-sm qty-step" data-step="2">+2</button>
                            <button type="button" class="btn btn-secondary btn-sm qty-step" data-step="4">+4</button>
                        </div>
                        <span asp-validation-for="Quantity" class="field-error"></span>
                        <p class="field-hint">@L["For Adjustment, enter the target stock count (0 writes off all stock)."]</p>
                        <p class="field-hint" id="stock-projection" hidden aria-live="polite">
                            @L["Resulting stock:"] <strong id="stock-projection-value"></strong>
                        </p>
                    </div>

                    <div class="field">
                        <label asp-for="Note" class="field-label">@L["Note"] <span class="optional">@L["(optional)"]</span></label>
                        <textarea asp-for="Note" class="field-textarea" placeholder="…"></textarea>
                        <span asp-validation-for="Note" class="field-error"></span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">@L["Record Movement"]</button>
                        <a href="@(ViewBag.ReturnUrl is string r ? Redirects.Safe(r) : Url.Action("Details", new { id = tire.Id }))" class="btn btn-secondary">@L["Cancel"]</a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            var qty = document.getElementById("Quantity");
            var radios = document.querySelectorAll("input[name='MovementType']");
            var row = document.getElementById("stock-projection");
            var value = document.getElementById("stock-projection-value");
            var hints = document.querySelectorAll("#mt-hint span[data-mt]");
            var current = @tire.Quantity;
            function selectedType() {
                var checked = document.querySelector("input[name='MovementType']:checked");
                return checked ? checked.value : "In";
            }
            function update() {
                var mt = selectedType();
                hints.forEach(function (h) { h.hidden = h.dataset.mt !== mt; });
                var q = parseInt(qty.value, 10);
                if (isNaN(q) || q < 0) { row.hidden = true; return; }
                var result = mt === "In" ? current + q
                           : mt === "Out" ? current - q
                           : q;
                row.hidden = false;
                value.textContent = result;
                value.classList.toggle("qty-low", result < 0);
            }
            qty.addEventListener("input", update);
            radios.forEach(function (r) { r.addEventListener("change", update); });
            document.querySelectorAll(".qty-step").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    var q = parseInt(qty.value, 10);
                    qty.value = (isNaN(q) || q < 0 ? 0 : q) + parseInt(btn.dataset.step, 10);
                    qty.dispatchEvent(new Event("input", { bubbles: true }));
                });
            });
            update();
        })();
    </script>
}
