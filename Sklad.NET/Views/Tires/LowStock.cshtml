@model IEnumerable<Sklad.Models.Tire>

@{
    ViewData["Title"] = L["Low Stock"].Value;
    var count = Model.Count();
}

<div class="page">
    <div class="container">

        <div class="page-head">
            <div>
                <div class="eyebrow @(count > 0 ? "is-alert" : "")">@L["Report"]</div>
                <h1 class="page-title">@L["Low Stock"]</h1>
                <p class="page-lede">
                    @if (count == 0)
                    {
                        <span>@L["All tires are at or above their minimum stock level."]</span>
                    }
                    else
                    {
                        <span><span class="accent">@count</span> @L["at or below minimum stock level"]</span>
                    }
                </p>
            </div>
            <div class="head-actions">
                <a asp-action="Index" class="btn btn-secondary btn-sm">@L["All Inventory"]</a>
            </div>
        </div>

        <div class="block">
            <div class="block-head">
                <h2 class="block-title @(count > 0 ? "is-alert" : "")">
                    @(count > 0 ? L["{0} requiring attention", count] : L["All stocked"])
                </h2>
            </div>

            <div class="table-scroll" tabindex="0" role="region" aria-label="@L["Low Stock"]">
                @if (!Model.Any())
                {
                    <div class="empty">
                        <strong>@L["Nothing below minimum"]</strong>
                        @L["Inventory is in good shape — no restock needed."]
                    </div>
                }
                else
                {
                    <table class="data-table data-table-wide">
                        <colgroup>
                            <col class="w-sku" /><col class="w-tire" /><col class="w-size" />
                            <col class="w-class" /><col class="w-stock" /><col class="w-def" />
                            <col class="w-loc" /><col class="w-act" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th scope="col">@L["SKU"]</th>
                                <th scope="col">@L["Tire"]</th>
                                <th scope="col">@L["Size"]</th>
                                <th scope="col">@L["Season"]</th>
                                <th scope="col" class="col-num">@L["Stock"]</th>
                                <th scope="col" class="col-num">@L["Deficit"]</th>
                                <th scope="col">@L["Location"]</th>
                                <th scope="col"><span class="visually-hidden">@L["Actions"]</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model)
                            {
                                int deficit = t.MinStock - t.Quantity;
                                <tr class="is-low">
                                    <td class="mono"><a class="row-link" asp-action="Details" asp-route-id="@t.Id">@t.Sku</a></td>
                                    <td>
                                        <a class="row-link" asp-action="Details" asp-route-id="@t.Id">
                                            <span class="cell-stack cell-strong">@t.Brand</span>
                                            <span class="cell-sub">@t.Model</span>
                                        </a>
                                    </td>
                                    <td class="mono">@t.Size</td>
                                    <td><span class="tag">@L[Enums.Key(t.Season)]</span></td>
                                    <td class="col-num">
                                        <span class="cell-stack qty-low">@t.Quantity</span>
                                        <span class="cell-sub">@L["/ min {0}", t.MinStock]</span>
                                    </td>
                                    <td class="col-num deficit">@(deficit > 0 ? $"+{deficit}" : "—")</td>
                                    <td class="cell-muted">@(t.Location ?? "—")</td>
                                    <td>
                                        <div class="row-actions">
                                            <a asp-action="RegisterMovement" asp-route-id="@t.Id" asp-route-type="@MovementType.In" asp-route-returnUrl="/Tires/LowStock">@L["Move"]</a>
                                            <a asp-action="Edit" asp-route-id="@t.Id" asp-route-returnUrl="/Tires/LowStock">@L["Edit"]</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

    </div>
</div>
