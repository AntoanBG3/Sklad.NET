<!DOCTYPE html>
@{
    var ctrl = ViewContext.RouteData.Values["controller"] as string;
    var act = ViewContext.RouteData.Values["action"] as string;
    var isLowStock = ctrl == "Tires" && act == "LowStock";
    var isReport = ctrl == "Tires" && act == "Report";
    var isMovements = ctrl == "Movements";
    var isInventory = ctrl == "Tires" && !isLowStock && !isReport;
    var isPurchasing = ctrl is "Suppliers" or "PurchaseOrders";
    var isUsers = ctrl == "Users";
    var isSettings = ctrl == "ShopSettings";
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var here = $"{Context.Request.Path}{Context.Request.QueryString}";
    var authed = User.Identity?.IsAuthenticated == true;
}
<html lang="@lang">
<head>
    <partial name="_Head" />
</head>
<body>
    <a class="skip-link" href="#main-content">@L["Skip to content"]</a>
    <header class="topbar">
        <div class="container topbar-row">
            <a class="wordmark" asp-controller="Tires" asp-action="Index">
                <span class="wordmark-sklad">Sklad</span><span class="mark-index">@L["Tire Warehouse"]</span>
            </a>
            @if (authed)
            {
                <button type="button" class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="topnav">
                    <span class="nav-toggle-icon" aria-hidden="true"></span>@L["Menu"]
                </button>
            }
            <nav class="topnav @(authed ? "" : "topnav-simple")" id="topnav" aria-label="@L["Main navigation"]">
                @if (authed)
                {
                    <div class="topnav-links">
                        <a class="@(isInventory ? "is-active" : "")" aria-current="@(isInventory ? "page" : null)" asp-controller="Tires" asp-action="Index">@L["Inventory"]</a>
                        <a class="@(isLowStock ? "is-active" : "")" aria-current="@(isLowStock ? "page" : null)" asp-controller="Tires" asp-action="LowStock">@L["Low Stock"]</a>
                        <a class="@(isMovements ? "is-active" : "")" aria-current="@(isMovements ? "page" : null)" asp-controller="Movements" asp-action="Index">@L["Movements"]</a>
                        <a class="@(isPurchasing ? "is-active" : "")" aria-current="@(isPurchasing ? "page" : null)" asp-controller="PurchaseOrders" asp-action="Index">@L["Purchasing"]</a>
                        <a class="@(isReport ? "is-active" : "")" aria-current="@(isReport ? "page" : null)" asp-controller="Tires" asp-action="Report">@L["Stock Value"]</a>
                        @if (User.IsInRole(nameof(Sklad.Models.UserRole.Admin)))
                        {
                            <a class="@(isUsers ? "is-active" : "")" aria-current="@(isUsers ? "page" : null)" asp-controller="Users" asp-action="Index">@L["Users"]</a>
                            <a class="@(isSettings ? "is-active" : "")" aria-current="@(isSettings ? "page" : null)" asp-controller="ShopSettings" asp-action="Index">@L["Settings"]</a>
                        }
                    </div>
                }
                <div class="topnav-account">
                    <span class="lang" role="group" aria-label="@L["Language"]">
                        <a class="@(lang == "bg" ? "is-active" : "")" aria-current="@(lang == "bg" ? "true" : null)" asp-controller="Culture" asp-action="Set"
                           asp-route-culture="bg-BG" asp-route-returnUrl="@here">BG</a>
                        <a class="@(lang == "en" ? "is-active" : "")" aria-current="@(lang == "en" ? "true" : null)" asp-controller="Culture" asp-action="Set"
                           asp-route-culture="en-GB" asp-route-returnUrl="@here">EN</a>
                    </span>
                    @if (authed)
                    {
                        <form class="logout" asp-controller="Account" asp-action="Logout" method="post">
                            <span class="whoami">@User.Identity.Name</span>
                            <button type="submit" class="navlink">@L["Sign out"]</button>
                        </form>
                    }
                </div>
            </nav>
        </div>
    </header>

    <partial name="_Flash" model=@("container") />

    <main id="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <span>Sklad &mdash; @L["Tire Warehouse Management"]</span>
            <span>&copy; @DateTime.Now.Year</span>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
