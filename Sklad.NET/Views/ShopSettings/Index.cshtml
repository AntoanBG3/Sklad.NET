@model Sklad.ViewModels.ShopSettingsViewModel

@{
    ViewData["Title"] = L["Settings"].Value;
}

<div class="page">
    <div class="container container-narrow">

        <div class="page-head">
            <div>
                <div class="eyebrow">@L["Settings"]</div>
                <h1 class="page-title">@L["Shop Details"]</h1>
                <p class="page-lede">@L["Letterhead details for printed purchase orders, and shop-wide preferences."]</p>
            </div>
        </div>

        <form asp-action="Index" class="form" data-guard>

            <div asp-validation-summary="ModelOnly" class="form-errors"></div>

            <div class="form-section">
                <div class="form-section-title">@L["Company"]</div>
                <div class="field">
                    <label asp-for="Name" class="field-label">@L["Shop Name"] <span class="optional">@L["(optional)"]</span></label>
                    <input asp-for="Name" class="field-input" placeholder="Гуми Сервиз ЕООД" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div class="field">
                    <label asp-for="Address" class="field-label">@L["Address"] <span class="optional">@L["(optional)"]</span></label>
                    <textarea asp-for="Address" class="field-textarea" placeholder="ул. Витоша 1, 1000 София"></textarea>
                    <span asp-validation-for="Address" class="field-error"></span>
                </div>
                <div class="field">
                    <label asp-for="VatNumber" class="field-label">@L["VAT / EIK"] <span class="optional">@L["(optional)"]</span></label>
                    <input asp-for="VatNumber" class="field-input mono" placeholder="BG123456789" />
                    <span asp-validation-for="VatNumber" class="field-error"></span>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">@L["Contact"]</div>
                <div class="form-grid-2">
                    <div class="field">
                        <label asp-for="Phone" class="field-label">@L["Phone"] <span class="optional">@L["(optional)"]</span></label>
                        <input asp-for="Phone" class="field-input" placeholder="+359 ..." />
                        <span asp-validation-for="Phone" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Email" class="field-label">@L["Email"] <span class="optional">@L["(optional)"]</span></label>
                        <input asp-for="Email" class="field-input" placeholder="shop@example.com" />
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">@L["Preferences"]</div>
                <div class="form-grid-2">
                    <div class="field">
                        <label asp-for="DefaultCulture" class="field-label">@L["Default Language"]</label>
                        <select asp-for="DefaultCulture" class="field-select">
                            <option value="">@L["Bulgarian"]</option>
                            <option value="en-GB">@L["English"]</option>
                        </select>
                        <div class="field-hint">@L["Shown to visitors who have not picked a language."]</div>
                        <span asp-validation-for="DefaultCulture" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="PageSize" class="field-label">@L["Items per Page"] <span class="optional">@L["(optional)"]</span></label>
                        <input asp-for="PageSize" class="field-input" placeholder="50" />
                        <div class="field-hint">@L["Rows per table page, 10 to 200. Blank keeps 50."]</div>
                        <span asp-validation-for="PageSize" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="DefaultMinStock" class="field-label">@L["Default Min Stock"] <span class="optional">@L["(optional)"]</span></label>
                        <input asp-for="DefaultMinStock" class="field-input" />
                        <div class="field-hint">@L["Pre-fills Min Stock when adding a tire."]</div>
                        <span asp-validation-for="DefaultMinStock" class="field-error"></span>
                    </div>
                    <div class="field">
                        <label asp-for="ReportRangeMonths" class="field-label">@L["Report Range (Months)"] <span class="optional">@L["(optional)"]</span></label>
                        <input asp-for="ReportRangeMonths" class="field-input" placeholder="12" />
                        <div class="field-hint">@L["Default period of the Stock Value trend. Blank keeps 12 months."]</div>
                        <span asp-validation-for="ReportRangeMonths" class="field-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">@L["Save Settings"]</button>
                <a asp-controller="Tires" asp-action="Index" class="btn btn-secondary">@L["Cancel"]</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
