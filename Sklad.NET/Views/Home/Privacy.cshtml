@{
    ViewData["Title"] = L["Privacy Policy"].Value;
}

<div class="page">
    <div class="container">
        <div class="page-head">
            <div>
                <div class="eyebrow">@L["Legal"]</div>
                <h1 class="page-title">@L["Privacy Policy"]</h1>
                <p class="page-lede">@L["Use this page to detail your site's privacy policy."]</p>
            </div>
        </div>
    </div>
</div>
