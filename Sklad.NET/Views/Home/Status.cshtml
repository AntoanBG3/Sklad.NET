@{
    var code = (int)(ViewBag.Code ?? 500);
    var notFound = code == 404;
    ViewData["Title"] = notFound ? L["Page not found"].Value : L["Error"].Value;
}

<div class="page">
    <div class="container">
        <div class="page-head">
            <div>
                <div class="eyebrow is-alert">HTTP @code</div>
                <h1 class="page-title">@(notFound ? L["Page not found"] : L["Something went wrong"])</h1>
                <p class="page-lede">
                    @(notFound
                        ? L["The page you are looking for does not exist or was moved."]
                        : L["An error occurred while processing your request."])
                </p>
            </div>
            <div class="head-actions">
                <a asp-controller="Tires" asp-action="Index" class="btn btn-secondary btn-sm">@L["Back to Inventory"]</a>
            </div>
        </div>
    </div>
</div>
