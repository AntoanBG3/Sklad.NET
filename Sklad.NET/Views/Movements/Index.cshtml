@model Sklad.Services.PagedResult<Sklad.Models.StockMovement>

@{
    ViewData["Title"] = L["Movements"].Value;
    var type = ViewBag.Type as MovementType?;
    var tireId = ViewBag.TireId as int?;
    var tire = ViewBag.Tire as Sklad.Models.Tire;
}

<div class="page">
    <div class="container">

        <div class="page-head">
            <div>
                <div class="eyebrow">@L["Stock Ledger"]</div>
                <h1 class="page-title">@L["Movements"]</h1>
                <p class="page-lede">@L["{0} movements recorded.", Model.TotalCount]</p>
            </div>
            <div class="head-actions">
                <a asp-controller="Tires" asp-action="Index" class="btn btn-secondary btn-sm">@L["All Inventory"]</a>
            </div>
        </div>

        <div class="block">
            <div class="block-head">
                <span class="block-title">
                    @L["Movement History"]
                    @if (tire is not null)
                    {
                        <span class="block-title-context">&mdash; @tire.Brand @tire.Model (<a asp-action="Index" asp-route-type="@type">@L["Clear filter"]</a>)</span>
                    }
                </span>
                <span class="block-meta">
                    <a class="@(type is null ? "is-active" : "")" aria-current="@(type is null ? "true" : null)"
                       asp-action="Index" asp-route-tireId="@tireId">@L["All"]</a>
                    @foreach (MovementType mt in Enum.GetValues<MovementType>())
                    {
                        <a class="@(type == mt ? "is-active" : "")" aria-current="@(type == mt ? "true" : null)"
                           asp-action="Index" asp-route-type="@mt" asp-route-tireId="@tireId">@L[Enums.Key(mt)]</a>
                    }
                </span>
            </div>

            <div class="table-scroll">
                @if (!Model.Items.Any())
                {
                    <div class="empty">
                        <strong>@L["No movements yet"]</strong>
                        @L["Record a stock movement to start the audit trail."]
                    </div>
                }
                else
                {
                    <table class="data-table data-table-wide">
                        <colgroup>
                            <col class="w-mdate" /><col class="w-mtire" /><col class="w-mtype" />
                            <col class="w-mqty" /><col class="w-muser" /><col class="w-mnote" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th scope="col">@L["Date"]</th>
                                <th scope="col">@L["Tire"]</th>
                                <th scope="col">@L["Movement Type"]</th>
                                <th scope="col" class="col-num">@L["Quantity"]</th>
                                <th scope="col">@L["User"]</th>
                                <th scope="col">@L["Note"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.Items)
                            {
                                <tr>
                                    <td class="mono">@Dates.Stamp(m.Date)</td>
                                    <td>
                                        <a asp-controller="Tires" asp-action="Details" asp-route-id="@m.TireId">
                                            <span class="cell-stack cell-strong">@m.Tire.Brand @m.Tire.Model</span>
                                            <span class="cell-sub mono">@m.Tire.Sku</span>
                                        </a>
                                    </td>
                                    <td><span class="tag">@L[Enums.Key(m.MovementType)]</span></td>
                                    <td class="col-num">
                                        @(m.MovementType switch
                                        {
                                            MovementType.In => $"+{m.Quantity}",
                                            MovementType.Out => $"-{m.Quantity}",
                                            _ => $"={m.Quantity}"
                                        })
                                    </td>
                                    <td class="cell-muted">@(m.UserName ?? "—")</td>
                                    <td class="cell-muted">@(m.Note ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="pager">
                    @if (Model.HasPrevious)
                    {
                        <a class="btn btn-secondary btn-sm" asp-action="Index" asp-route-type="@type" asp-route-tireId="@tireId" asp-route-page="@(Model.Page - 1)">@L["Previous"]</a>
                    }
                    <span class="pager-info">@L["Page {0} of {1}", Model.Page, Model.TotalPages]</span>
                    @if (Model.HasNext)
                    {
                        <a class="btn btn-secondary btn-sm" asp-action="Index" asp-route-type="@type" asp-route-tireId="@tireId" asp-route-page="@(Model.Page + 1)">@L["Next"]</a>
                    }
                </div>
            }
        </div>

    </div>
</div>
